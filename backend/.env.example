# 環境變數示範

# LLM 配置
LLM_MODEL=llama3
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# TTS 配置
TTS_PROVIDER=edge-tts
TTS_VOICE=zh-HK-YurisNeural

# 對話配置
MAX_CONVERSATION_LENGTH=10
RESPONSE_TIMEOUT=30

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 數據庫
DATABASE_URL=sqlite:///./mean_ai.db
