# 環境變數示範

# LLM 配置
LLM_PROVIDER=ollama # 可選值：ollama、huggingface
LLM_MODEL=hon9kon9ize/CantoneseLLMChat-v1.0-7B
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# Hugging Face Inference Providers（當 LLM_PROVIDER=huggingface 時使用）
HF_TOKEN=
HF_PROVIDER=auto #featherless-ai

# TTS 配置
TTS_PROVIDER=edge-tts
TTS_VOICE=zh-HK-WanLungNeural

# 對話配置
MAX_CONVERSATION_LENGTH=10
RESPONSE_TIMEOUT=30

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 數據庫
DATABASE_URL=sqlite:///./mean_ai.db
